		"drizzle-orm": "^0.40.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.16.0",
		"@types/better-sqlite3": "^7.6.12",
		"autoprefixer": "^10.4.21",
		"drizzle-kit": "^0.30.5",
		"postcss": "^8.5.3",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.1",
